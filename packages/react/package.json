{
  "name": "@hi-design/react",
  "version": "1.0.0",
  "description": "React components for HI Design System - based on design-tokens.pen",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@hi-design/primitives": "workspace:*",
    "@hi-design/tokens": "workspace:*",
    "@hi-design/types": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "catalog:",
    "@storybook/addon-interactions": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@storybook/testing-library": "^0.2.2",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "catalog:",
    "react": "^18.3.0",
    "storybook": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "catalog:"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system"
  ],
  "author": "HI Design System",
  "license": "MIT"
}
