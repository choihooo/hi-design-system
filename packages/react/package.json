{
  "name": "@hi-design/react",
  "version": "0.1.0",
  "description": "React web components for HI Design System",
  "main": "./dist/hi-design.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/hi-design.es.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": "./src/components/*/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@hi-design/icons": "workspace:*",
    "@hi-design/primitives": "workspace:*",
    "@hi-design/tokens": "workspace:*",
    "@hi-design/types": "workspace:*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "hi-design"
  ],
  "author": "HI Design System",
  "license": "MIT"
}
