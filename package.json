{
  "name": "hi-design-system",
  "version": "0.0.1",
  "private": true,
  "description": "AI-friendly design system for React web applications",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:affected": "turbo run build --filter=[HEAD^1]",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:parallel": "turbo run test --parallel",
    "test:affected": "turbo run test --filter=[HEAD^1]",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm test:run && pnpm test:e2e",
    "coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome check .",
    "lint:affected": "turbo run lint --filter=[HEAD^1]",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "type-check": "turbo run type-check",
    "type-check:affected": "turbo run type-check --filter=[HEAD^1]",
    "ai-score": "node scripts/measure-ai-score.js",
    "ai-score-full": "node scripts/measure-full-package.js",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "check-circular": "madge --circular --extensions ts,tsx packages/*/src",
    "dep-health": "pnpm dependency-health",
    "dep-graph": "turbo run build --dry-run --force",
    "perf:build": "time pnpm turbo run build --force",
    "perf:test": "time pnpm turbo run test --force"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@phosphor-icons/core": "catalog:",
    "@playwright/test": "catalog:",
    "@semantic-release/changelog": "catalog:",
    "@semantic-release/commit-analyzer": "catalog:",
    "@semantic-release/git": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/npm": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-essentials": "catalog:",
    "@storybook/addon-interactions": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "8.6.14",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jsdom": "catalog:",
    "madge": "^8.0.0",
    "rimraf": "^6.1.3",
    "semantic-release": "catalog:",
    "storybook": "catalog:",
    "tsup": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
